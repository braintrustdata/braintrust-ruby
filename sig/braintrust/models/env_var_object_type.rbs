module Braintrust
  module Models
    type env_var_object_type = :organization | :project | :function

    module EnvVarObjectType
      extend Braintrust::Enum

      ORGANIZATION: :organization
      PROJECT: :project
      FUNCTION: :function

      def self?.values: -> ::Array[Braintrust::Models::env_var_object_type]
    end
  end
end
