module Braintrust
  module Models
    type code_bundle =
      {
        bundle_id: String,
        location: Braintrust::Models::CodeBundle::location,
        runtime_context: Braintrust::Models::CodeBundle::RuntimeContext,
        preview: String?
      }

    class CodeBundle < Braintrust::Internal::Type::BaseModel
      attr_accessor bundle_id: String

      attr_accessor location: Braintrust::Models::CodeBundle::location

      attr_accessor runtime_context: Braintrust::Models::CodeBundle::RuntimeContext

      attr_accessor preview: String?

      def initialize: (
        bundle_id: String,
        location: Braintrust::Models::CodeBundle::location,
        runtime_context: Braintrust::Models::CodeBundle::RuntimeContext,
        ?preview: String?
      ) -> void

      def to_hash: -> Braintrust::Models::code_bundle

      type location =
        Braintrust::Models::CodeBundle::Location::Experiment
        | Braintrust::Models::CodeBundle::Location::Function

      module Location
        extend Braintrust::Internal::Type::Union

        type experiment =
          {
            eval_name: String,
            position: Braintrust::Models::CodeBundle::Location::Experiment::position,
            type: Braintrust::Models::CodeBundle::Location::Experiment::type_
          }

        class Experiment < Braintrust::Internal::Type::BaseModel
          attr_accessor eval_name: String

          attr_accessor position: Braintrust::Models::CodeBundle::Location::Experiment::position

          attr_accessor type: Braintrust::Models::CodeBundle::Location::Experiment::type_

          def initialize: (
            eval_name: String,
            position: Braintrust::Models::CodeBundle::Location::Experiment::position,
