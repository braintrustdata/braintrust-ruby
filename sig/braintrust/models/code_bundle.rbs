        end

        def self?.variants: -> [Braintrust::Models::CodeBundle::Location::Experiment, Braintrust::Models::CodeBundle::Location::Function]
      end

      type runtime_context =
        {
          runtime: Braintrust::Models::CodeBundle::RuntimeContext::runtime,
          version: String
        }

      class RuntimeContext < Braintrust::Internal::Type::BaseModel
        attr_accessor runtime: Braintrust::Models::CodeBundle::RuntimeContext::runtime

