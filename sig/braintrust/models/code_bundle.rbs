          ) -> void

          def to_hash: -> Braintrust::Models::CodeBundle::Location::function

          type type_ = :function

          module Type
            extend Braintrust::Internal::Type::Enum

            FUNCTION: :function

            def self?.values: -> ::Array[Braintrust::Models::CodeBundle::Location::Function::type_]
