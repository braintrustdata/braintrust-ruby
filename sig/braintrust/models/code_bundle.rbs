                type: Braintrust::Models::CodeBundle::Location::Experiment::Position::Type::type_
              }

            class Type < Braintrust::Internal::Type::BaseModel
              attr_accessor type: Braintrust::Models::CodeBundle::Location::Experiment::Position::Type::type_

              def initialize: (
                type: Braintrust::Models::CodeBundle::Location::Experiment::Position::Type::type_
              ) -> void

              def to_hash: -> Braintrust::Models::CodeBundle::Location::Experiment::Position::type_

              type type_ = :task

              module Type
                extend Braintrust::Internal::Type::Enum

                TASK: :task

                def self?.values: -> ::Array[Braintrust::Models::CodeBundle::Location::Experiment::Position::Type::type_]
              end
            end

            type scorer =
              {
                index: Integer,
                type: Braintrust::Models::CodeBundle::Location::Experiment::Position::Scorer::type_
              }

            class Scorer < Braintrust::Internal::Type::BaseModel
              attr_accessor index: Integer

              attr_accessor type: Braintrust::Models::CodeBundle::Location::Experiment::Position::Scorer::type_

              def initialize: (
                index: Integer,
                type: Braintrust::Models::CodeBundle::Location::Experiment::Position::Scorer::type_
              ) -> void

              def to_hash: -> Braintrust::Models::CodeBundle::Location::Experiment::Position::scorer

              type type_ = :scorer

              module Type
                extend Braintrust::Internal::Type::Enum

                SCORER: :scorer

                def self?.values: -> ::Array[Braintrust::Models::CodeBundle::Location::Experiment::Position::Scorer::type_]
              end
            end

            def self?.variants: -> [Braintrust::Models::CodeBundle::Location::Experiment::Position::Type, Braintrust::Models::CodeBundle::Location::Experiment::Position::Scorer]
          end

          type type_ = :experiment

          module Type
            extend Braintrust::Internal::Type::Enum

            EXPERIMENT: :experiment

            def self?.values: -> ::Array[Braintrust::Models::CodeBundle::Location::Experiment::type_]
          end
        end

        type function =
          {
            index: Integer,
            type: Braintrust::Models::CodeBundle::Location::Function::type_
          }

        class Function < Braintrust::Internal::Type::BaseModel
          attr_accessor index: Integer

          attr_accessor type: Braintrust::Models::CodeBundle::Location::Function::type_

          def initialize: (
