module Braintrust
  module Models
    type prompt_options =
      {
        model: String,
        params: Braintrust::PromptOptions::params,
        position: String
      }

    class PromptOptions < Braintrust::Internal::Type::BaseModel
      attr_reader model: String?

      def model=: (String) -> String

      attr_reader params: Braintrust::PromptOptions::params?

      def params=: (
        Braintrust::PromptOptions::params
      ) -> Braintrust::PromptOptions::params

      attr_reader position: String?

      def position=: (String) -> String

      def initialize: (
        ?model: String,
        ?params: Braintrust::PromptOptions::params,
        ?position: String
      ) -> void

      type params =
        Braintrust::PromptOptions::Params::OpenAIModelParams
        | Braintrust::PromptOptions::Params::AnthropicModelParams
        | Braintrust::PromptOptions::Params::GoogleModelParams
        | Braintrust::PromptOptions::Params::WindowAIModelParams
        | Braintrust::PromptOptions::Params::JsCompletionParams

      module Params
        extend Braintrust::Internal::Type::Union

        type openai_model_params =
          {
            frequency_penalty: Float,
            function_call: Braintrust::PromptOptions::Params::OpenAIModelParams::function_call,
            max_completion_tokens: Float,
            max_tokens: Float,
            n: Float,
            presence_penalty: Float,
            reasoning_effort: Braintrust::PromptOptions::Params::OpenAIModelParams::reasoning_effort,
            response_format: Braintrust::PromptOptions::Params::OpenAIModelParams::response_format?,
            stop: ::Array[String],
            temperature: Float,
            tool_choice: Braintrust::PromptOptions::Params::OpenAIModelParams::tool_choice,
            top_p: Float,
            use_cache: bool
          }

        class OpenAIModelParams < Braintrust::Internal::Type::BaseModel
          attr_reader frequency_penalty: Float?

          def frequency_penalty=: (Float) -> Float

          attr_reader function_call: Braintrust::PromptOptions::Params::OpenAIModelParams::function_call?

          def function_call=: (
            Braintrust::PromptOptions::Params::OpenAIModelParams::function_call
          ) -> Braintrust::PromptOptions::Params::OpenAIModelParams::function_call

          attr_reader max_completion_tokens: Float?

          def max_completion_tokens=: (Float) -> Float

          attr_reader max_tokens: Float?

          def max_tokens=: (Float) -> Float

          attr_reader n: Float?

          def n=: (Float) -> Float

          attr_reader presence_penalty: Float?

          def presence_penalty=: (Float) -> Float

          attr_reader reasoning_effort: Braintrust::PromptOptions::Params::OpenAIModelParams::reasoning_effort?

          def reasoning_effort=: (
            Braintrust::PromptOptions::Params::OpenAIModelParams::reasoning_effort
          ) -> Braintrust::PromptOptions::Params::OpenAIModelParams::reasoning_effort

          attr_accessor response_format: Braintrust::PromptOptions::Params::OpenAIModelParams::response_format?

          attr_reader stop: ::Array[String]?

          def stop=: (::Array[String]) -> ::Array[String]

          attr_reader temperature: Float?

          def temperature=: (Float) -> Float

          attr_reader tool_choice: Braintrust::PromptOptions::Params::OpenAIModelParams::tool_choice?

          def tool_choice=: (
            Braintrust::PromptOptions::Params::OpenAIModelParams::tool_choice
          ) -> Braintrust::PromptOptions::Params::OpenAIModelParams::tool_choice

          attr_reader top_p: Float?

          def top_p=: (Float) -> Float

          attr_reader use_cache: bool?

          def use_cache=: (bool) -> bool

          def initialize: (
            ?frequency_penalty: Float,
            ?function_call: Braintrust::PromptOptions::Params::OpenAIModelParams::function_call,
            ?max_completion_tokens: Float,
            ?max_tokens: Float,
            ?n: Float,
            ?presence_penalty: Float,
            ?reasoning_effort: Braintrust::PromptOptions::Params::OpenAIModelParams::reasoning_effort,
            ?response_format: Braintrust::PromptOptions::Params::OpenAIModelParams::response_format?,
            ?stop: ::Array[String],
            ?temperature: Float,
            ?tool_choice: Braintrust::PromptOptions::Params::OpenAIModelParams::tool_choice,
            ?top_p: Float,
            ?use_cache: bool
          ) -> void

          type function_call =
            :auto
            | :none
            | Braintrust::PromptOptions::Params::OpenAIModelParams::FunctionCall::Function

          module FunctionCall
            extend Braintrust::Internal::Type::Union

            type function = { name: String }

            class Function < Braintrust::Internal::Type::BaseModel
              attr_accessor name: String

              def initialize: (name: String) -> void
            end

            def self?.variants: -> ::Array[Braintrust::PromptOptions::Params::OpenAIModelParams::function_call]

            AUTO: :auto
            NONE: :none
          end

          type reasoning_effort = :low | :medium | :high

          module ReasoningEffort
            extend Braintrust::Internal::Type::Enum

            LOW: :low
            MEDIUM: :medium
            HIGH: :high

            def self?.values: -> ::Array[Braintrust::PromptOptions::Params::OpenAIModelParams::reasoning_effort]
          end

          type response_format =
            Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonObject
            | Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonSchema
            | Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::Text

          module ResponseFormat
            extend Braintrust::Internal::Type::Union

            type json_object =
              {
                type: Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonObject::type_
              }

            class JsonObject < Braintrust::Internal::Type::BaseModel
              attr_accessor type: Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonObject::type_

              def initialize: (
                type: Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonObject::type_
              ) -> void

              type type_ = :json_object

              module Type
                extend Braintrust::Internal::Type::Enum

                JSON_OBJECT: :json_object

                def self?.values: -> ::Array[Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonObject::type_]
              end
            end

            type json_schema =
              {
                json_schema: Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonSchema::JsonSchema,
                type: Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonSchema::type_
              }

            class JsonSchema < Braintrust::Internal::Type::BaseModel
              attr_accessor json_schema: Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonSchema::JsonSchema

              attr_accessor type: Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonSchema::type_

              def initialize: (
                json_schema: Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonSchema::JsonSchema,
                type: Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonSchema::type_
              ) -> void

              type json_schema =
                {
                  name: String,
                  description: String,
                  schema: Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonSchema::JsonSchema::schema,
                  strict: bool?
                }

              class JsonSchema < Braintrust::Internal::Type::BaseModel
                attr_accessor name: String

                attr_reader description: String?

                def description=: (String) -> String

                attr_reader schema: Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonSchema::JsonSchema::schema?

                def schema=: (
                  Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonSchema::JsonSchema::schema
                ) -> Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonSchema::JsonSchema::schema

                attr_accessor strict: bool?

                def initialize: (
                  name: String,
                  ?description: String,
                  ?schema: Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonSchema::JsonSchema::schema,
                  ?strict: bool?
                ) -> void

                type schema = ::Hash[Symbol, top?] | String

                module Schema
                  extend Braintrust::Internal::Type::Union

                  def self?.variants: -> ::Array[Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonSchema::JsonSchema::schema]

                  ObjectMap: Braintrust::Internal::Type::Converter
                end
              end

              type type_ = :json_schema

              module Type
                extend Braintrust::Internal::Type::Enum

                JSON_SCHEMA: :json_schema

                def self?.values: -> ::Array[Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::JsonSchema::type_]
              end
            end

            type text =
              {
                type: Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::Text::type_
              }

            class Text < Braintrust::Internal::Type::BaseModel
              attr_accessor type: Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::Text::type_

              def initialize: (
                type: Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::Text::type_
              ) -> void

              type type_ = :text

              module Type
                extend Braintrust::Internal::Type::Enum

                TEXT: :text

                def self?.values: -> ::Array[Braintrust::PromptOptions::Params::OpenAIModelParams::ResponseFormat::Text::type_]
              end
            end

            def self?.variants: -> ::Array[Braintrust::PromptOptions::Params::OpenAIModelParams::response_format]
          end

          type tool_choice =
            :auto
            | :none
            | :required
            | Braintrust::PromptOptions::Params::OpenAIModelParams::ToolChoice::Function

          module ToolChoice
            extend Braintrust::Internal::Type::Union

            type function =
              {
                function: Braintrust::PromptOptions::Params::OpenAIModelParams::ToolChoice::Function::Function,
                type: Braintrust::PromptOptions::Params::OpenAIModelParams::ToolChoice::Function::type_
              }

            class Function < Braintrust::Internal::Type::BaseModel
              attr_accessor function: Braintrust::PromptOptions::Params::OpenAIModelParams::ToolChoice::Function::Function

              attr_accessor type: Braintrust::PromptOptions::Params::OpenAIModelParams::ToolChoice::Function::type_

              def initialize: (
                function: Braintrust::PromptOptions::Params::OpenAIModelParams::ToolChoice::Function::Function,
                type: Braintrust::PromptOptions::Params::OpenAIModelParams::ToolChoice::Function::type_
              ) -> void

              type function = { name: String }

              class Function < Braintrust::Internal::Type::BaseModel
                attr_accessor name: String

                def initialize: (name: String) -> void
              end

              type type_ = :function

              module Type
                extend Braintrust::Internal::Type::Enum

                FUNCTION: :function

                def self?.values: -> ::Array[Braintrust::PromptOptions::Params::OpenAIModelParams::ToolChoice::Function::type_]
              end
            end

            def self?.variants: -> ::Array[Braintrust::PromptOptions::Params::OpenAIModelParams::tool_choice]

            AUTO: :auto
            NONE: :none
            REQUIRED: :required
          end
        end

        type anthropic_model_params =
          {
            max_tokens: Float,
            temperature: Float,
            max_tokens_to_sample: Float,
            stop_sequences: ::Array[String],
            top_k: Float,
            top_p: Float,
            use_cache: bool
          }

        class AnthropicModelParams < Braintrust::Internal::Type::BaseModel
          attr_accessor max_tokens: Float

          attr_accessor temperature: Float

          attr_reader max_tokens_to_sample: Float?

          def max_tokens_to_sample=: (Float) -> Float

          attr_reader stop_sequences: ::Array[String]?

          def stop_sequences=: (::Array[String]) -> ::Array[String]

          attr_reader top_k: Float?

          def top_k=: (Float) -> Float

          attr_reader top_p: Float?

          def top_p=: (Float) -> Float

          attr_reader use_cache: bool?

          def use_cache=: (bool) -> bool

          def initialize: (
