        end

        type js_completion_params = { use_cache: bool }

        class JsCompletionParams < Braintrust::Internal::Type::BaseModel
          attr_reader use_cache: bool?

          def use_cache=: (bool) -> bool

          def initialize: (?use_cache: bool) -> void
        end

        def self?.variants: -> ::Array[Braintrust::PromptOptions::params]
