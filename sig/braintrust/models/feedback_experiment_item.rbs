module Braintrust
  module Models
    type feedback_experiment_item =
      {
        id: String,
        comment: String?,
        expected: top,
        metadata: ::Hash[Symbol, top?]?,
        scores: ::Hash[Symbol, Float?]?,
        source: Braintrust::Models::FeedbackExperimentItem::source?,
        tags: ::Array[String]?
      }

    class FeedbackExperimentItem < Braintrust::BaseModel
      attr_accessor id: String

      attr_accessor comment: String?

      attr_reader expected: top?

      def expected=: (top) -> top

      attr_accessor metadata: ::Hash[Symbol, top?]?

      attr_accessor scores: ::Hash[Symbol, Float?]?

      attr_accessor source: Braintrust::Models::FeedbackExperimentItem::source?

      attr_accessor tags: ::Array[String]?

      def initialize: (
        id: String,
        ?comment: String?,
        ?expected: top,
        ?metadata: ::Hash[Symbol, top?]?,
        ?scores: ::Hash[Symbol, Float?]?,
        ?source: Braintrust::Models::FeedbackExperimentItem::source?,
        ?tags: ::Array[String]?
      ) -> void

      def to_hash: -> Braintrust::Models::feedback_experiment_item

      type source = :app | :api | :external

      module Source
        extend Braintrust::Enum

        APP: :app
        API: :api
        EXTERNAL: :external

        def self?.values: -> ::Array[Braintrust::Models::FeedbackExperimentItem::source]
      end
    end
  end
end
