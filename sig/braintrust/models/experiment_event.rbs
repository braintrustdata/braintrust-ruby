module Braintrust
  module Models
    type experiment_event =
      {
        id: String,
        _xact_id: String,
        created: Time,
        experiment_id: String,
        project_id: String,
        root_span_id: String,
        span_id: String,
        context: Braintrust::Models::ExperimentEvent::Context?,
        dataset_record_id: String?,
        error: top,
        expected: top,
        input: top,
        is_root: bool?,
        metadata: ::Hash[Symbol, top?]?,
        metrics: Braintrust::Models::ExperimentEvent::Metrics?,
        origin: Braintrust::Models::ExperimentEvent::Origin?,
        output: top,
        scores: ::Hash[Symbol, Float?]?,
        span_attributes: Braintrust::Models::SpanAttributes?,
        span_parents: ::Array[String]?,
        tags: ::Array[String]?
      }

    class ExperimentEvent < Braintrust::BaseModel
      attr_accessor id: String

      attr_accessor _xact_id: String

      attr_accessor created: Time

      attr_accessor experiment_id: String

      attr_accessor project_id: String

      attr_accessor root_span_id: String

      attr_accessor span_id: String

      attr_accessor context: Braintrust::Models::ExperimentEvent::Context?

      attr_accessor dataset_record_id: String?

      attr_reader error: top?

      def error=: (top) -> top

      attr_reader expected: top?

      def expected=: (top) -> top

      attr_reader input: top?

      def input=: (top) -> top

      attr_accessor is_root: bool?

      attr_accessor metadata: ::Hash[Symbol, top?]?

      attr_accessor metrics: Braintrust::Models::ExperimentEvent::Metrics?

      attr_accessor origin: Braintrust::Models::ExperimentEvent::Origin?

      attr_reader output: top?

      def output=: (top) -> top

      attr_accessor scores: ::Hash[Symbol, Float?]?

      attr_accessor span_attributes: Braintrust::Models::SpanAttributes?

      attr_accessor span_parents: ::Array[String]?

      attr_accessor tags: ::Array[String]?

      def initialize:
        (
          id: String,
          _xact_id: String,
          created: Time,
          experiment_id: String,
          project_id: String,
          root_span_id: String,
          span_id: String,
          context: Braintrust::Models::ExperimentEvent::Context?,
          dataset_record_id: String?,
          error: top,
          expected: top,
          input: top,
          is_root: bool?,
          metadata: ::Hash[Symbol, top?]?,
          metrics: Braintrust::Models::ExperimentEvent::Metrics?,
          origin: Braintrust::Models::ExperimentEvent::Origin?,
          output: top,
          scores: ::Hash[Symbol, Float?]?,
          span_attributes: Braintrust::Models::SpanAttributes?,
          span_parents: ::Array[String]?,
          tags: ::Array[String]?
        ) -> void
        | (
          ?Braintrust::Models::experiment_event | Braintrust::BaseModel data
        ) -> void

      def to_hash: -> Braintrust::Models::experiment_event

      type context =
        {
          caller_filename: String?,
          caller_functionname: String?,
          caller_lineno: Integer?
        }

      class Context < Braintrust::BaseModel
        attr_accessor caller_filename: String?

        attr_accessor caller_functionname: String?

        attr_accessor caller_lineno: Integer?

        def initialize:
          (
            caller_filename: String?,
            caller_functionname: String?,
            caller_lineno: Integer?
          ) -> void
          | (
            ?Braintrust::Models::ExperimentEvent::context
            | Braintrust::BaseModel data
          ) -> void

        def to_hash: -> Braintrust::Models::ExperimentEvent::context
      end

      type metrics =
        {
          caller_filename: top,
          caller_functionname: top,
          caller_lineno: top,
          completion_tokens: Integer?,
          end_: Float?,
          prompt_tokens: Integer?,
          start: Float?,
          tokens: Integer?
        }

      class Metrics < Braintrust::BaseModel
        attr_reader caller_filename: top?

        def caller_filename=: (top) -> top

        attr_reader caller_functionname: top?

        def caller_functionname=: (top) -> top

        attr_reader caller_lineno: top?

        def caller_lineno=: (top) -> top

        attr_accessor completion_tokens: Integer?

        attr_accessor end_: Float?

        attr_accessor prompt_tokens: Integer?

        attr_accessor start: Float?

        attr_accessor tokens: Integer?

        def initialize:
          (
            caller_filename: top,
            caller_functionname: top,
            caller_lineno: top,
            completion_tokens: Integer?,
            end_: Float?,
            prompt_tokens: Integer?,
            start: Float?,
            tokens: Integer?
          ) -> void
          | (
            ?Braintrust::Models::ExperimentEvent::metrics
            | Braintrust::BaseModel data
          ) -> void

        def to_hash: -> Braintrust::Models::ExperimentEvent::metrics
      end

      type origin =
        {
          id: String,
          _xact_id: String,
          object_id_: String,
          object_type: Braintrust::Models::ExperimentEvent::Origin::object_type
        }

      class Origin < Braintrust::BaseModel
        attr_accessor id: String

        attr_accessor _xact_id: String

        attr_accessor object_id_: String

        attr_accessor object_type: Braintrust::Models::ExperimentEvent::Origin::object_type

        def initialize:
          (
            id: String,
            _xact_id: String,
            object_id_: String,
            object_type: Braintrust::Models::ExperimentEvent::Origin::object_type
          ) -> void
          | (
            ?Braintrust::Models::ExperimentEvent::origin
            | Braintrust::BaseModel data
          ) -> void

        def to_hash: -> Braintrust::Models::ExperimentEvent::origin

        type object_type =
          :experiment
          | :dataset
          | :prompt
          | :function
          | :prompt_session
          | :project_logs

        class ObjectType < Braintrust::Enum
          EXPERIMENT: :experiment
          DATASET: :dataset
          PROMPT: :prompt
          FUNCTION: :function
          PROMPT_SESSION: :prompt_session
          PROJECT_LOGS: :project_logs

          def self.values: -> ::Array[Braintrust::Models::ExperimentEvent::Origin::object_type]
        end
      end
    end
  end
end
