module Braintrust
  module Models
    type span_attributes =
      { name: String?, type: Braintrust::Models::span_type? }

    class SpanAttributes < Braintrust::Internal::Type::BaseModel
      attr_accessor name: String?

      attr_accessor type: Braintrust::Models::span_type?

      def initialize: (
        ?name: String?,
        ?type: Braintrust::Models::span_type?
      ) -> void
    end
  end
end
