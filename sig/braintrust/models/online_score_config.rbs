        scorers: ::Array[Braintrust::Models::OnlineScoreConfig::scorer],
        apply_to_root_span: bool?,
        apply_to_span_names: ::Array[String]?
      }

      type scorer =
        Braintrust::OnlineScoreConfig::Scorer::Function
        | Braintrust::OnlineScoreConfig::Scorer::Global

      module Scorer
        extend Braintrust::Internal::Type::Union

        type function =
          {
            id: String,
            type: Braintrust::Models::OnlineScoreConfig::Scorer::Function::type_
          }

        class Function < Braintrust::Internal::Type::BaseModel
          attr_accessor id: String

