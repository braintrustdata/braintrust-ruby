          }

        class Global < Braintrust::BaseModel
          attr_accessor name: String

          attr_accessor type: Braintrust::Models::OnlineScoreConfig::Scorer::Global::type_

          def initialize: (
            name: String,
            type: Braintrust::Models::OnlineScoreConfig::Scorer::Global::type_
          ) -> void

          def to_hash: -> Braintrust::Models::OnlineScoreConfig::Scorer::global

          type type_ = :global

          class Type < Braintrust::Enum
            GLOBAL: :global

            def self.values: -> ::Array[Braintrust::Models::OnlineScoreConfig::Scorer::Global::type_]
