      def to_hash: -> Braintrust::Models::online_score_config

      type scorer =
        Braintrust::Models::OnlineScoreConfig::Scorer::Function
        | Braintrust::Models::OnlineScoreConfig::Scorer::Global

      class Scorer < Braintrust::Union
        type function =
