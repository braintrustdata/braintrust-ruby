            id: String,
            type: Braintrust::Models::OnlineScoreConfig::Scorer::Function::type_
          }

        class Function < Braintrust::BaseModel
          attr_accessor id: String

          attr_accessor type: Braintrust::Models::OnlineScoreConfig::Scorer::Function::type_

