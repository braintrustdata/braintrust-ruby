        type global =
          {
            name: String,
            type: Braintrust::Models::OnlineScoreConfig::Scorer::Global::type_
          }

        class Global < Braintrust::Internal::Type::BaseModel
          attr_accessor name: String

          attr_accessor type: Braintrust::Models::OnlineScoreConfig::Scorer::Global::type_

          def initialize: (
            name: String,
            type: Braintrust::Models::OnlineScoreConfig::Scorer::Global::type_
          ) -> void

          def to_hash: -> {
            name: String,
            type: Braintrust::Models::OnlineScoreConfig::Scorer::Global::type_
          }

          type type_ = :global

          module Type
